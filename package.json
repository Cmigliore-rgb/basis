{
  "name": "peakledger",
  "version": "1.0.0",
  "description": "PeakLedger personal finance platform",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently --names \"backend,frontend\" --prefix-colors \"blue,green\" \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "electron:dev": "electron .",
    "electron:build": "electron-builder build --win",
    "build:frontend": "cd frontend && npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.PeakLedger.app",
    "productName": "PeakLedger",
    "electronVersion": "42.1.0",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "concurrently": "^9.2.1",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1"
  }
}
