{
  "name": "basis",
  "version": "1.0.0",
  "description": "Basis personal finance platform",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently --names \"backend,frontend\" --prefix-colors \"blue,green\" \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "electron:dev": "electron .",
    "electron:build": "npm run build:frontend && npx @electron/rebuild --module-dir backend && electron-builder build --win",
    "build:frontend": "cd frontend && npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.basis.app",
    "productName": "Basis",
    "electronVersion": "30.5.1",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": ["**/*", "!ledger.db", "!data.json", "!server.log", "!*.pem", "!*.zip"]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "concurrently": "^9.2.1",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0"
  }
}
