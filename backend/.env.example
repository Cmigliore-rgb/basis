# Plaid — https://dashboard.plaid.com
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox
PLAID_REDIRECT_URI=http://localhost:5173/oauth-return

# Teller — https://teller.io/dashboard
TELLER_APP_ID=your_teller_app_id
# Place certificate.pem and private_key.pem in backend/ (download from Teller dashboard)

# Groq — https://console.groq.com
GROQ_API_KEY=your_groq_api_key

PORT=3001
